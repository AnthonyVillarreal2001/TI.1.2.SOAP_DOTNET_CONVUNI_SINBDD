@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.Title = "Inicio de Sesión";
}

<style>
    /* Tarjeta blanca semitransparente */
    .login-card {
        background: rgba(255, 255, 255, 0.95);
        border-radius: 20px;
        padding: 30px 25px;
        box-shadow: 0 12px 40px rgba(0, 0, 0, 0.25);
        color: #1E293B;
        width: 100%;
        max-width: 380px;
        margin: 20px;
        text-align: center;
        backdrop-filter: blur(5px);
    }

    .login-icon {
        font-size: 2.5rem;
        margin-bottom: 5px;
        color: #8B5CF6;
    }

    .login-title {
        font-size: 2rem;
        font-weight: 700;
        color: #5B2C8E;
        margin: 0 0 25px 0;
    }

    .input-group {
        margin-bottom: 18px;
        text-align: left;
    }

        .input-group label {
            display: block;
            font-weight: 600;
            color: #5B2C8E;
            margin-bottom: 6px;
            font-size: 0.9rem;
        }

        .input-group input {
            width: 100%;
            padding: 12px 14px;
            border: 2px solid #8B5CF6;
            border-radius: 12px;
            font-size: 1rem;
            background: #F8FAFC;
            color: #1E293B;
            outline: none;
            transition: border-color 0.2s;
        }

            .input-group input:focus {
                border-color: #14B8A6;
                box-shadow: 0 0 0 3px rgba(20,184,166,0.2);
            }

    .btn-login {
        width: 100%;
        padding: 14px;
        border: none;
        border-radius: 14px;
        font-weight: 700;
        font-size: 1.1rem;
        color: white;
        background: linear-gradient(90deg, #8B5CF6 0%, #14B8A6 100%);
        cursor: pointer;
        box-shadow: 0 6px 20px rgba(20,184,166,0.4);
        transition: all 0.3s ease;
        margin-top: 10px;
    }

        .btn-login:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 25px rgba(20,184,166,0.5);
        }

        .btn-login:active {
            transform: translateY(0);
        }

        .btn-login.loading {
            background: #14B8A6;
            pointer-events: none;
        }

    .error-msg {
        background: rgba(248, 113, 113, 0.15);
        border: 1px solid #EF4444;
        color: #B91C1C;
        padding: 10px 15px;
        border-radius: 10px;
        margin-bottom: 20px;
        font-size: 0.9rem;
    }

    .credits {
        margin-top: 30px;
        color: rgba(255, 255, 255, 0.8);
        font-size: 0.75rem;
        text-align: center;
    }
</style>

<div class="login-card">
    <div class="login-icon">🚪</div>
    <h1 class="login-title">¡Bienvenido!</h1>

    @if (ViewBag.Error != null)
    {
        <div class="error-msg">⚠️ @ViewBag.Error</div>
    }

    @using (Html.BeginForm("Login", "Account", FormMethod.Post))
    {
        @Html.AntiForgeryToken()

        <div class="input-group">
            <label>Usuario</label>
            <input type="text" name="username" placeholder="MONSTER" required autofocus />
        </div>

        <div class="input-group">
            <label>Contraseña</label>
            <input type="password" name="password" placeholder="••••••••" required />
        </div>

        <button type="submit" class="btn-login" id="loginBtn">INGRESAR</button>
    }
</div>

<div class="credits">👾 Hecho por: Ariel R. y Anthony V.</div>

@section scripts {
    <script>
    const form = document.querySelector('form');
    const btn = document.getElementById('loginBtn');
    form.addEventListener('submit', function () {
        btn.classList.add('loading');
        btn.textContent = 'INGRESANDO...';
    });
    </script>
}